[user]
    name  = nixy
    email = for.ritindersingh@gmail.com

[init]
    defaultBranch = main

[push]
    autoSetupRemote = true

[pull]
    rebase = true

[diff]
    colorMoved = default

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate     = true
    side-by-side = true
    line-numbers = true
    syntax-theme = base16

[merge]
    conflictstyle = diff3

[rebase]
    autoStash = true

[alias]
    lg = log --oneline --graph --decorate --all

[ignore]
    .DS_Store
    *.swp
    .direnv
    .envrc
    *.log
